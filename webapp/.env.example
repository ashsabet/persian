# Copy to .env and fill in. The web process reads these at startup.
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=persian.ashkon.net,192.168.1.10,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://persian.ashkon.net

# Postgres (leave blank to fall back to local SQLite for development)
POSTGRES_DB=persian
POSTGRES_USER=persian
POSTGRES_PASSWORD=
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Path to the Piper voice .onnx (used by `manage.py generate_audio`)
PIPER_MODEL=/opt/piper/voices/fa_IR-gyro-medium.onnx

# Email for password-reset links. Leave EMAIL_HOST blank to just log the email
# (testing). For real delivery set your SMTP server details:
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=Persian <no-reply@persian.ashkon.net>
